---
import Base from "../layouts/Base.astro";
---

<Base title="Candide · Wild Ordinary">
  <div class="lab-stage">

    <header class="top">
      <h1>Wild Ordinary — clickable prototype</h1>
      <p>Real content · one day, end to end. Tap through, or jump with the map below.</p>
    </header>

    <div class="stage">
    <div class="phone">
      <div class="notch"></div>
      <div class="statusbar"><span>9:41</span><span class="dots">●●● ▭</span></div>

      <!-- 0 ONBOARDING -->
      <section class="screen active" data-i="0">
        <a class="lablink" href="/candide-strategy-lab">‹ strategy lab</a>
        <div class="tag">first run</div>
        <div class="spacer"></div>
        <img class="ch" src="/assets/candide/cut/rooster.png" alt="Candide" style="height:132px;align-self:center;">
        <h2 style="text-align:center;">Let's build Lila's<br>storybook.</h2>
        <p class="lead" style="text-align:center;">A hundred small adventures are hidden inside ordinary days. You do one together — then I turn it into a page you keep forever.</p>
        <div class="pill" style="align-self:center;">100 wild-ordinary moments · 0 found</div>
        <div class="spacer"></div>
        <button class="btn" onclick="go(1)">Start today</button>
        <p class="dim" style="text-align:center;">Everything stays on this phone.</p>
      </section>

      <!-- 1 SETUP / MOOD -->
      <section class="screen" data-i="1">
        <div class="back" onclick="go(0)">‹ back</div>
        <div class="tag">setup · D</div>
        <div style="margin-top:4px;">
          <div class="kick">Shape the moment</div>
          <h2>How's right now?</h2>
        </div>
        <div class="chipgrp"><span class="lbl">How long</span><div class="chips">
          <span class="chip on">5 min</span><span class="chip">15 min</span><span class="chip">20+ min</span></div></div>
        <div class="chipgrp"><span class="lbl">Her energy</span><div class="chips">
          <span class="chip">Wound up</span><span class="chip on">Restless</span><span class="chip">Calm</span></div></div>
        <div class="chipgrp"><span class="lbl">Where</span><div class="chips">
          <span class="chip on">Inside</span><span class="chip">Outside</span></div></div>
        <div class="spacer"></div>
        <button class="btn ghost" onclick="go(2)">Pick by value</button>
        <button class="btn" onclick="go(3)">Choose for me →</button>
      </section>

      <!-- 2 VALUE PICKER -->
      <section class="screen" data-i="2">
        <div class="back" onclick="go(1)">‹ back</div>
        <div class="tag">by value</div>
        <div style="margin-top:4px;">
          <div class="kick">Pick a friend to host</div>
          <h2>What to grow in Lila?</h2>
        </div>
        <div class="vgrid">
          <div class="vchip"><div class="av"><img class="ch" src="/assets/candide/cut/rooster.png" alt="Candide"></div><b>Gratitude</b><small>with Candide</small></div>
          <div class="vchip"><div class="av"><img class="ch" src="/assets/candide/cut/monster.png" alt="Boro"></div><b>Big feelings</b><small>with Boro</small></div>
          <div class="vchip"><div class="av"><img class="ch" src="/assets/candide/cut/fox.png" alt="Theo"></div><b>Patience</b><small>with Theo</small></div>
          <div class="vchip on"><div class="av"><img class="ch" src="/assets/candide/cut/monkey.png" alt="Momo"></div><b>Trying new things</b><small>with Momo</small></div>
          <div class="vchip"><div class="av"><img class="ch" src="/assets/candide/cut/tallman.png" alt="Step"></div><b>Being brave</b><small>with Step</small></div>
          <div class="vchip"><div class="av"><img class="ch" src="/assets/candide/cut/frog.png" alt="Kiko"></div><b>Big energy</b><small>with Kiko</small></div>
        </div>
        <div class="spacer"></div>
        <button class="btn" onclick="go(3)">See tonight's adventure →</button>
      </section>

      <!-- 3 DARE HOME -->
      <section class="screen" data-i="3">
        <div class="tag">C · the dare</div>
        <div class="kick">Wild Ordinary</div>
        <div><div class="dim">Hi Kara</div><h2>Today's dare is in.</h2></div>
        <div class="bookbar"><b>Book of 100</b><div class="bar"><i style="width:6%"></i></div><b>6 found</b></div>
        <div class="dare">
          <div class="inner">
            <img class="ch" id="hostimg" src="/assets/candide/cut/monkey.png" alt="Momo" style="height:88px;">
            <div class="from" id="from">Momo dares you & Lila</div>
            <div class="quote" id="quote">“Build me a hideout from three soft things — then climb in and tell each other the scariest thing that isn’t actually scary.”</div>
            <div class="meta" id="meta">5–20 min · inside · pillows & blankets</div>
            <div class="swapped" id="pill">✦ swapped — your one for today</div>
          </div>
          <canvas class="scratchcanvas" id="scratch"></canvas>
        </div>
        <div class="dareActions" id="dareActions">
          <div class="btnrow">
            <button class="btn" style="flex:2;" onclick="go(4)">▶ Take the dare</button>
            <button class="btn ghost" id="swapBtn" style="flex:1;" onclick="openSwap()">Swap</button>
          </div>
        </div>
        <div class="listrow" onclick="go(8)"><span style="font-size:22px;">📖</span>
          <div style="flex:1;"><b>Lila's storybook</b><br><small>6 pages so far · tap to read</small></div><span class="dim">›</span></div>

        <div class="scrim" id="scrim" onclick="closeSwap()"></div>
        <div class="sheet" id="sheet">
          <h3>Not today?</h3>
          <p class="dim" style="margin-top:-4px;">Tell us why — we'll find one that fits. Just one swap.</p>
          <div class="reason" onclick="pickReason('calm')">Too wild <small>want calmer</small></div>
          <div class="reason" onclick="pickReason('energy')">Too calm <small>want to move</small></div>
          <div class="reason" onclick="pickReason('nostuff')">No stuff <small>nothing to build with</small></div>
          <div class="reason" onclick="pickReason('done')">Already did it</div>
          <div class="cancel" onclick="closeSwap()">never mind</div>
        </div>
      </section>

      <!-- 4 ACTIVITY INTRO -->
      <section class="screen" data-i="4">
        <div class="back" onclick="go(3)">‹ home</div>
        <div class="tag">C · invite</div>
        <div class="photo" style="height:150px;margin-top:4px;">MOMO'S CORNER OF THE WORLD<br>(host art, breathing)</div>
        <div class="row"><div class="av"><img class="ch" src="/assets/candide/cut/monkey.png" alt="Momo"></div><div><b style="font-size:16px;">Build it for Momo</b><br><span class="dim">hosted by Momo</span></div></div>
        <p class="lead">Momo's corner of the world feels a little empty right now. He's never had anywhere to hide. Build him one from three soft things — then squeeze in together and trade the scariest thing that isn't actually scary.</p>
        <div><span class="pill">Trying new things · spatial play & problem-solving</span></div>
        <div class="spacer"></div>
        <button class="btn" onclick="go(5)">How do we play? →</button>
      </section>

      <!-- 5 HOW TO PLAY -->
      <section class="screen" data-i="5">
        <div class="back" onclick="go(4)">‹ back</div>
        <div class="tag">C · play</div>
        <div class="kick">Step by step · away from the screen</div>
        <h2>Build the hideout</h2>
        <div class="step"><div class="n">1</div><span>Pull two chairs back-to-back, a little apart.</span></div>
        <div class="step"><div class="n">2</div><span>Drape your biggest blanket over the top.</span></div>
        <div class="step"><div class="n">3</div><span>Tuck cushions inside for a soft floor.</span></div>
        <div class="step"><div class="n">4</div><span>Leave one gap open — that's Momo's door.</span></div>
        <div class="step"><div class="n">5</div><span>Fold a towel into a tiny bed for him.</span></div>
        <div class="step"><div class="n">6</div><span>Climb in together — then take turns: the scariest thing that isn't actually scary.</span></div>
        <p class="dim" style="text-align:center;">The build is the warm-up. The sharing is the point.</p>
        <button class="btn" onclick="go(6)">We built it — snap it →</button>
      </section>

      <!-- 6 CAPTURE -->
      <section class="screen cam" data-i="6">
        <div class="back" onclick="go(5)" style="color:#d7d6df;">‹ back</div>
        <div class="tag">B · capture</div>
        <div class="vf"><div class="lbl">Point at the hideout<br>you built together</div></div>
        <div style="text-align:center;color:#f2f1f6;font-size:14px;font-weight:700;">Snap Momo's hideout</div>
        <div class="shutter" onclick="go(7)"></div>
        <div style="text-align:center;color:#9b9aa4;font-size:10.5px;">Stays on this phone. Nothing uploaded, ever.</div>
      </section>

      <!-- 7 MEMORY NOTE -->
      <section class="screen" data-i="7">
        <div class="back" onclick="go(6)">‹ retake</div>
        <div class="tag">B · keep it</div>
        <div class="photo" style="height:150px;margin-top:4px;">THE PHOTO YOU JUST TOOK</div>
        <h3>Anything you want to remember?</h3>
        <div class="note">Lila named it “the cave” and refused to come out for dinner.</div>
        <p class="dim">A line for you — Candide writes the story.</p>
        <div class="spacer"></div>
        <button class="btn ghost" onclick="go(10)">Skip</button>
        <button class="btn" onclick="go(10)">Add it to the storybook →</button>
      </section>

      <!-- 8 READ CHOOSER -->
      <section class="screen" data-i="8">
        <div class="tag">A · how to read</div>
        <div style="margin-top:4px;"><div class="kick">Tell the story</div><h2>How shall we read it?</h2></div>
        <div class="ropt on" onclick="go(9)"><span class="ic">📖</span><div><b>Read together on screen</b><small>flip the pages, side by side</small></div></div>
        <div class="ropt" onclick="go(9)"><span class="ic">🌙</span><div><b>Listen in the dark</b><small>Momo reads aloud, phone face-down</small></div></div>
        <div class="ropt" onclick="go(9)"><span class="ic">✂️</span><div><b>Print the little book</b><small>one folded sheet, no screen at all</small></div></div>
        <div class="ropt" onclick="go(9)"><span class="ic">🕯️</span><div><b>Parent-reading mode</b><small>you read from a dim script; Lila just listens</small></div></div>
      </section>

      <!-- 9 BEDTIME BOOK -->
      <section class="screen" data-i="9" style="background:var(--sky);">
        <div class="back" onclick="go(3)">‹ home</div>
        <div class="tag">A · the book</div>
        <div class="kick" style="text-align:center;">A new page · told by Momo</div>
        <div class="bookwrap">
          <div class="book">
            <div class="pg photo" style="border-radius:0;border:none;">YOUR PHOTO — THE REAL HIDEOUT<div class="overlay"><img class="ch" src="/assets/candide/cut/monkey.png" alt="Momo" style="height:104px;"></div></div>
            <div class="txt">
              <p>“You built me a cave out of two chairs and the blue blanket. We squeezed inside, and Lila told me the scariest thing that isn't really scary — the vacuum — and then I told her mine. After we said them out loud, neither one was scary anymore. I think I'll live here now.”</p>
              <div class="narr"><img class="ch chin" src="/assets/candide/cut/monkey.png" alt="Momo"> told by Momo · from the photo you took</div>
            </div>
          </div>
          <div class="livedbar">✦ 7 of 100 lived · 93 still hidden</div>
        </div>
        <button class="btn plum" onclick="go(3)">The end →</button>
      </section>

      <!-- 10 CLOSE -->
      <section class="screen" data-i="10">
        <div class="tag">saved</div>
        <div class="kick" style="margin-top:4px;">Kept on this phone, forever</div>
        <h2>Saved to Lila's storybook.</h2>
        <div class="card" style="gap:13px;">
          <div class="row">
            <div class="photo" style="width:72px;height:72px;border-radius:13px;flex:none;font-size:9px;">YOUR PHOTO</div>
            <div><b style="font-size:15px;">Build it for Momo</b><br><span class="dim"><img class="ch chin" src="/assets/candide/cut/monkey.png" alt="Momo"> Trying new things · today</span></div>
          </div>
          <div class="note" style="min-height:auto;padding:11px 13px;">“Lila named it ‘the cave’ and refused to come out for dinner.”</div>
          <div class="livedbar" style="justify-content:flex-start;">✦ 7 of 100 lived · 93 still hidden</div>
        </div>
        <div class="card"><div class="row"><span style="font-size:22px;">✦</span>
          <div><b>Soft close</b><br><span class="dim">“Is Momo still worried? How does your body feel now?”</span></div></div></div>
        <div class="spacer"></div>
        <p class="dim" style="text-align:center;">Read it whenever you like — from Lila's storybook.</p>
        <button class="btn" onclick="go(3)">Again tomorrow →</button>
      </section>

    </div>

    <aside class="annot" style="max-width:280px;font-size:12px;color:#56544f;line-height:1.65;">
      <div style="font-size:11px;letter-spacing:1.2px;text-transform:uppercase;color:#8c8a83;margin-bottom:8px;">What got ironed out</div>
      <p style="margin-bottom:9px;"><b>One home, not two.</b> The "pick a game" deck is gone — the daily dare is the game. Home = scratch the dare.</p>
      <p style="margin-bottom:9px;"><b>Three steering tools, one job.</b> Setup filters, value picker, and Swap all narrow the same pool. Setup/value run at first-run; Swap is the daily escape hatch.</p>
      <p style="margin-bottom:9px;"><b>All six characters carry a value</b> (incl. Theo = patience), so none is orphaned.</p>
      <p><b>Real copy throughout</b> — "Lila" is a sample name; swap in the real child at sign-up.</p>
    </aside>
    </div>

    <footer class="flowmap" id="map"></footer>

  </div>
</Base>

<style>
  :global(.site-header),
  :global(.site-footer) {
    display: none;
  }

  :root{
    --bg:#eceae4; --panel:#ffffff; --ink:#2b2a28; --dim:#8c8a83;
    --line:#e2e0d8; --line2:#d4d2c9; --plum:#5a2d52; --pink:#e0457e; --pinkdeep:#b82f63;
    --pink2:#fbeaf0; --mint:#3c9b63; --mint2:#e9f6ee; --sky:#eaf2f6;
  }
  *{box-sizing:border-box;margin:0;-webkit-font-smoothing:antialiased;
    font-family:"Segoe UI","Avenir Next",system-ui,-apple-system,sans-serif;}
  .lab-stage{background:var(--bg);color:var(--ink);display:flex;flex-direction:column;align-items:center;
    min-height:100dvh;padding:22px 16px 70px;gap:16px;}
  header.top{text-align:center;max-width:440px;}
  header.top h1{font-size:18px;font-weight:700;color:var(--plum);}
  header.top p{font-size:12.5px;color:var(--dim);margin-top:4px;line-height:1.5;}
  .stage{display:flex;align-items:flex-start;gap:20px;}

  .phone{width:340px;height:710px;background:var(--panel);border-radius:42px;position:relative;
    overflow:hidden;flex:none;box-shadow:0 0 0 2px var(--ink),0 18px 40px rgba(0,0,0,.22);}
  .statusbar{position:absolute;top:0;left:0;right:0;height:40px;display:flex;align-items:center;
    justify-content:space-between;padding:0 26px;font-size:12px;font-weight:700;color:var(--ink);z-index:60;}
  .statusbar .dots{display:flex;gap:4px;align-items:center;}
  .notch{position:absolute;top:11px;left:50%;transform:translateX(-50%);width:104px;height:24px;
    background:var(--ink);border-radius:14px;z-index:61;}
  .screen{position:absolute;inset:0;display:none;flex-direction:column;padding:48px 20px 18px;gap:13px;overflow-y:auto;}
  .screen.active{display:flex;}

  .tag{position:absolute;top:46px;right:16px;font-size:9px;font-weight:800;letter-spacing:.7px;
    background:var(--plum);color:#fff;border-radius:7px;padding:4px 7px;z-index:40;text-transform:uppercase;}
  .back{position:absolute;top:46px;left:14px;font-size:12.5px;font-weight:700;color:var(--dim);cursor:pointer;z-index:40;padding:3px 5px;}
  .lablink{position:absolute;top:46px;left:14px;font-size:12.5px;font-weight:700;color:var(--dim);cursor:pointer;z-index:40;padding:3px 5px;text-decoration:none;}
  .lablink:hover{color:var(--plum);}
  .kick{font-size:10px;font-weight:800;letter-spacing:1.4px;text-transform:uppercase;color:var(--dim);}
  h2{font-size:23px;font-weight:700;line-height:1.18;color:var(--ink);letter-spacing:-.2px;}
  h3{font-size:16px;font-weight:700;}
  .lead{font-size:14px;line-height:1.6;color:#55534e;}
  .dim{color:var(--dim);font-size:12.5px;line-height:1.5;}
  .spacer{flex:1;}

  .btn{display:block;width:100%;text-align:center;padding:15px;border:none;border-radius:15px;
    background:var(--pink);color:#fff;font-size:15.5px;font-weight:700;cursor:pointer;letter-spacing:.2px;}
  .btn:active{transform:translateY(1px);}
  .btn.dark{background:var(--ink);}
  .btn.ghost{background:#fff;color:var(--ink);border:1.6px solid var(--line2);}
  .btn.plum{background:var(--plum);}
  .btnrow{display:flex;gap:10px;}
  .link{font-size:13px;font-weight:700;color:var(--plum);text-align:center;cursor:pointer;text-decoration:underline;text-underline-offset:3px;}

  .photo{border:1.6px dashed var(--line2);border-radius:16px;background:
    repeating-linear-gradient(45deg,#f4f3ef,#f4f3ef 8px,#ecebe5 8px,#ecebe5 16px);
    display:flex;align-items:center;justify-content:center;text-align:center;color:var(--dim);
    font-size:11px;font-weight:700;padding:12px;}
  .av{width:52px;height:52px;border-radius:50%;background:var(--pink2);display:flex;align-items:center;
    justify-content:center;font-size:26px;flex:none;}
  .av.lg{width:76px;height:76px;font-size:40px;}
  .ch{display:block;object-fit:contain;}
  .av img.ch{width:100%;height:100%;object-fit:contain;padding:9%;}
  img.chin{height:18px;width:18px;object-fit:contain;vertical-align:-4px;display:inline-block;}
  .card{border:1.4px solid var(--line);border-radius:16px;background:#fff;padding:15px;display:flex;flex-direction:column;gap:11px;}
  .row{display:flex;align-items:center;gap:11px;}
  .pill{display:inline-block;font-size:11px;font-weight:700;color:var(--plum);background:var(--pink2);border-radius:20px;padding:5px 11px;}

  /* progress */
  .bookbar{display:flex;align-items:center;gap:10px;border:1.4px solid var(--line);border-radius:13px;background:#fff;padding:10px 13px;}
  .bookbar .bar{flex:1;height:8px;border-radius:6px;background:var(--line);position:relative;overflow:hidden;}
  .bookbar .bar i{position:absolute;left:0;top:0;bottom:0;background:var(--pink);}
  .bookbar b{font-size:12px;font-weight:700;white-space:nowrap;}

  /* chips */
  .chipgrp{display:flex;flex-direction:column;gap:7px;}
  .chipgrp .lbl{font-size:11px;font-weight:800;letter-spacing:.5px;color:var(--dim);text-transform:uppercase;}
  .chips{display:flex;gap:7px;flex-wrap:wrap;}
  .chip{border:1.5px solid var(--line2);border-radius:11px;background:#fff;padding:9px 13px;font-size:13px;font-weight:700;cursor:pointer;color:#55534e;}
  .chip.on{border-color:var(--pink);background:var(--pink2);color:var(--plum);}

  /* value grid */
  .vgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
  .vchip{border:1.5px solid var(--line2);border-radius:15px;background:#fff;padding:13px 11px;display:flex;
    flex-direction:column;align-items:center;gap:5px;cursor:pointer;text-align:center;}
  .vchip.on{border-color:var(--pink);background:var(--pink2);}
  .vchip .av{width:42px;height:42px;font-size:22px;background:#f4f3ef;}
  .vchip.on .av{background:#fff;}
  .vchip b{font-size:13.5px;font-weight:700;}
  .vchip small{font-size:10.5px;color:var(--dim);font-weight:600;}

  /* dare */
  .dare{position:relative;flex:1;border-radius:20px;overflow:hidden;min-height:250px;}
  .inner{position:absolute;inset:0;z-index:1;background:var(--pink2);display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:12px;text-align:center;padding:24px;}
  .inner .from{font-size:11px;font-weight:800;letter-spacing:.6px;color:var(--pinkdeep);text-transform:uppercase;}
  .inner .quote{font-size:19px;font-weight:700;line-height:1.38;color:var(--plum);}
  .inner .meta{font-size:12px;color:#8a6076;font-weight:600;}
  .swapped{font-size:10px;font-weight:800;letter-spacing:.4px;color:#fff;background:var(--plum);border-radius:20px;padding:4px 11px;display:none;}
  .swapped.show{display:inline-block;}
  .cover{position:absolute;inset:0;z-index:5;cursor:pointer;display:flex;flex-direction:column;align-items:center;
    justify-content:center;gap:12px;text-align:center;padding:24px;
    background:repeating-linear-gradient(45deg,#efeae0,#efeae0 12px,#e6e0d4 12px,#e6e0d4 24px);
    transition:opacity .5s ease,transform .5s ease;}
  .cover .seal{width:84px;height:84px;border-radius:50%;border:2px dashed var(--plum);background:#fff;display:flex;
    align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--plum);text-align:center;line-height:1.2;}
  .cover .big{font-size:20px;font-weight:700;color:var(--ink);}
  .cover .hint{font-size:12px;color:#6f6e68;font-weight:600;}
  .cover .tapme{font-size:11.5px;font-weight:800;letter-spacing:.6px;color:#fff;background:var(--pink);border-radius:12px;padding:8px 14px;animation:pulse 1.6s infinite;}
  @keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.05);}}
  .cover.gone{opacity:0;transform:scale(1.05);pointer-events:none;}
  .scratchcanvas{position:absolute;inset:0;z-index:5;cursor:grab;touch-action:none;}
  .scratchcanvas:active{cursor:grabbing;}
  .dareActions{opacity:0;transform:translateY(6px);pointer-events:none;transition:opacity .35s ease,transform .35s ease;}
  .dareActions.show{opacity:1;transform:none;pointer-events:auto;}

  /* sheet */
  .scrim{position:absolute;inset:0;z-index:70;background:rgba(43,42,40,.45);display:none;}
  .scrim.show{display:block;}
  .sheet{position:absolute;left:0;right:0;bottom:0;z-index:71;background:#fff;border-radius:24px 24px 0 0;
    padding:20px 18px 24px;transform:translateY(100%);transition:transform .32s ease;display:flex;flex-direction:column;gap:9px;}
  .sheet.show{transform:translateY(0);}
  .reason{border:1.5px solid var(--line2);border-radius:13px;background:#fff;padding:13px 14px;display:flex;
    align-items:center;justify-content:space-between;cursor:pointer;font-size:14px;font-weight:700;}
  .reason small{font-size:11px;color:var(--dim);font-weight:600;}
  .cancel{text-align:center;font-size:12.5px;color:var(--dim);cursor:pointer;font-weight:700;padding-top:3px;}

  /* steps */
  .step{border:1.4px solid var(--line);border-radius:13px;background:#fff;padding:12px;display:flex;align-items:center;gap:12px;}
  .step .n{width:26px;height:26px;border-radius:50%;background:var(--pink2);color:var(--plum);display:flex;align-items:center;
    justify-content:center;font-size:13px;font-weight:800;flex:none;}
  .step span{font-size:13.5px;font-weight:600;line-height:1.35;}

  /* camera */
  .cam{background:#16151a;}
  .vf{flex:1;border-radius:18px;border:2px solid rgba(255,255,255,.45);position:relative;overflow:hidden;
    display:flex;align-items:flex-end;justify-content:center;padding:16px;
    background:repeating-linear-gradient(45deg,#23222a,#23222a 9px,#1d1c23 9px,#1d1c23 18px);}
  .vf .lbl{color:#d7d6df;font-size:12px;font-weight:700;text-align:center;}
  .shutter{width:64px;height:64px;border-radius:50%;background:#fff;border:5px solid rgba(255,255,255,.4);cursor:pointer;align-self:center;}

  /* note */
  .note{border:1.5px solid var(--line2);border-radius:14px;background:#fff;padding:13px;font-size:13.5px;line-height:1.55;
    color:#55534e;min-height:96px;font-style:italic;}

  /* read options */
  .ropt{border:1.5px solid var(--line2);border-radius:14px;background:#fff;padding:13px 14px;display:flex;align-items:center;gap:12px;cursor:pointer;}
  .ropt .ic{font-size:22px;flex:none;}
  .ropt b{font-size:14px;font-weight:700;display:block;}
  .ropt small{font-size:11.5px;color:var(--dim);}
  .ropt.on{border-color:var(--pink);background:var(--pink2);}

  /* book */
  .bookwrap{flex:1;display:flex;flex-direction:column;justify-content:center;gap:13px;}
  .book{border:1.4px solid var(--line);border-radius:10px 18px 18px 10px;background:#fff;overflow:hidden;box-shadow:0 8px 20px rgba(80,40,70,.12);}
  .book .pg{height:230px;position:relative;}
  .book .pg .overlay{position:absolute;bottom:12px;left:52%;transform:translateX(-50%);width:84px;height:104px;
    display:flex;align-items:flex-end;justify-content:center;font-size:46px;}
  .book .txt{padding:14px 16px;}
  .book .txt p{font-size:14px;line-height:1.6;color:var(--ink);}
  .book .narr{margin-top:11px;font-size:10.5px;color:var(--dim);font-weight:700;letter-spacing:.3px;display:flex;align-items:center;gap:6px;}
  .livedbar{display:flex;align-items:center;justify-content:center;gap:8px;font-size:11.5px;font-weight:700;color:var(--plum);}

  /* home extras */
  .listrow{border:1.4px solid var(--line);border-radius:14px;background:#fff;padding:13px;display:flex;align-items:center;gap:12px;cursor:pointer;}
  .listrow b{font-size:14px;font-weight:700;}
  .listrow small{font-size:11.5px;color:var(--dim);}
  .nav{margin-top:auto;display:flex;align-items:center;justify-content:space-around;border-top:1.4px solid var(--line);padding-top:11px;}
  .nav .tab{display:flex;flex-direction:column;align-items:center;gap:3px;font-size:10px;font-weight:700;color:var(--dim);}
  .nav .tab.on{color:var(--plum);}
  .nav .tab .ic{font-size:19px;}

  footer.flowmap{display:flex;gap:6px;flex-wrap:wrap;justify-content:center;max-width:480px;}
  footer.flowmap button{font-size:10.5px;font-weight:700;border:1px solid var(--line2);background:#fff;color:var(--dim);
    border-radius:8px;padding:5px 9px;cursor:pointer;}
  footer.flowmap button.on{background:var(--plum);color:#fff;border-color:var(--plum);}

  @media (max-width:900px){
    .lab-stage{padding:0;gap:0;min-height:100dvh;background:var(--panel);}
    .stage{width:100%;gap:0;}
    .phone{width:100%;height:100dvh;max-width:100%;border-radius:0;box-shadow:none;}
    header.top,aside.annot,footer.flowmap{display:none;}
    .statusbar,.notch{display:none;}
    /* keep top-pinned chrome and screen content clear of the notch / status bar */
    .screen{padding-top:calc(env(safe-area-inset-top) + 48px);}
    .back,.tag,.lablink{top:calc(env(safe-area-inset-top) + 46px);}
  }
</style>

<script is:inline>
  var screens=document.querySelectorAll('.screen');
  var labels=['0 Onboard','1 Setup','2 Value','3 Dare home','4 Invite','5 Play','6 Capture','7 Note','8 Read?','9 Book','10 Saved'];
  var map=document.getElementById('map');
  labels.forEach(function(l,i){var b=document.createElement('button');b.textContent=l;b.onclick=function(){go(i);};map.appendChild(b);});
  function go(i){
    screens.forEach(function(s){s.classList.remove('active');});
    screens[i].classList.add('active');screens[i].scrollTop=0;
    map.querySelectorAll('button').forEach(function(b,j){b.classList.toggle('on',j===i);});
    if(i===3){setTimeout(resetDare,30);}
  }
  document.querySelectorAll('.chip').forEach(function(c){
    c.onclick=function(){
      var sibs=c.parentElement.querySelectorAll('.chip');
      sibs.forEach(function(s){s.classList.remove('on');});c.classList.add('on');
    };
  });
  document.querySelectorAll('.vchip').forEach(function(v){
    v.onclick=function(){document.querySelectorAll('.vchip').forEach(function(x){x.classList.remove('on');});v.classList.add('on');};
  });
  document.querySelectorAll('.ropt').forEach(function(r){
    r.onclick=function(){document.querySelectorAll('.ropt').forEach(function(x){x.classList.remove('on');});r.classList.add('on');};
  });
  var alts={
    calm:['monster.png','Boro asks you & Lila','“Make a nest where you two just fit — then whisper one thing that felt too big today.”','5 min · inside · one blanket'],
    energy:['frog.png','Kiko dares you & Lila','“Spin three times, freeze like statues — then each shout the silliest thing that makes you laugh.”','5 min · just space'],
    nostuff:['fox.png','Theo dares you & Lila','“Cross the room without one sound — then tell each other one tiny thing nobody else noticed today.”','5 min · nothing needed'],
    done:['tallman.png','Step dares you & Lila','“Move the heaviest thing you two can lift somewhere new — then each name one thing you’re braver about than last year.”','10 min · anything heavy-ish']
  };
  var swapUsed=false;
  function openSwap(){if(swapUsed)return;
    document.getElementById('scrim').classList.add('show');document.getElementById('sheet').classList.add('show');}
  function closeSwap(){document.getElementById('scrim').classList.remove('show');document.getElementById('sheet').classList.remove('show');}
  function pickReason(k){var a=alts[k];
    document.getElementById('hostimg').src='/assets/candide/cut/'+a[0];
    document.getElementById('from').textContent=a[1];document.getElementById('quote').textContent=a[2];
    document.getElementById('meta').textContent=a[3];document.getElementById('pill').classList.add('show');
    swapUsed=true;var b=document.getElementById('swapBtn');b.classList.add('ghost');b.style.opacity=.55;
    b.textContent='one a day';b.setAttribute('onclick','');closeSwap();}

  // --- real scratch-to-reveal ---
  var cv=document.getElementById('scratch'),ctx=cv.getContext('2d'),scratching=false,scratchDone=false;
  function paintCover(){
    var w=cv.width,h=cv.height;
    ctx.globalCompositeOperation='source-over';
    ctx.fillStyle='#e9e3d8';ctx.fillRect(0,0,w,h);
    ctx.strokeStyle='#ded6c7';ctx.lineWidth=11;
    for(var x=-h;x<w;x+=24){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x+h,h);ctx.stroke();}
    ctx.textAlign='center';
    ctx.fillStyle='#5a2d52';ctx.font='800 17px "Segoe UI",system-ui,sans-serif';
    ctx.fillText('SCRATCH TO REVEAL',w/2,h/2-4);
    ctx.fillStyle='#6f6e68';ctx.font='600 12px "Segoe UI",system-ui,sans-serif';
    ctx.fillText('one a day — a friend picked it for Lila',w/2,h/2+18);
  }
  function initScratch(){
    var d=cv.parentElement,w=d.clientWidth,h=d.clientHeight;
    if(!w||!h)return;
    cv.width=w;cv.height=h;paintCover();scratchDone=false;
  }
  function eraseAt(px,py){
    var r=cv.getBoundingClientRect();
    var x=(px-r.left)*(cv.width/r.width),y=(py-r.top)*(cv.height/r.height);
    ctx.globalCompositeOperation='destination-out';
    ctx.beginPath();ctx.arc(x,y,28,0,Math.PI*2);ctx.fill();
    checkScratch();
  }
  function checkScratch(){
    if(scratchDone)return;
    var data=ctx.getImageData(0,0,cv.width,cv.height).data,clear=0,total=0;
    for(var i=3;i<data.length;i+=160){total++;if(data[i]===0)clear++;}
    if(total&&clear/total>0.55)revealDare();
  }
  function revealDare(){
    scratchDone=true;
    cv.style.transition='opacity .4s ease';cv.style.opacity=0;
    setTimeout(function(){cv.style.display='none';},420);
    document.getElementById('dareActions').classList.add('show');
  }
  function xy(e){return e.touches&&e.touches[0]?[e.touches[0].clientX,e.touches[0].clientY]:[e.clientX,e.clientY];}
  cv.addEventListener('mousedown',function(e){scratching=true;var p=xy(e);eraseAt(p[0],p[1]);});
  window.addEventListener('mousemove',function(e){if(scratching){var p=xy(e);eraseAt(p[0],p[1]);}});
  window.addEventListener('mouseup',function(){scratching=false;});
  cv.addEventListener('touchstart',function(e){scratching=true;var p=xy(e);eraseAt(p[0],p[1]);e.preventDefault();},{passive:false});
  cv.addEventListener('touchmove',function(e){if(scratching){var p=xy(e);eraseAt(p[0],p[1]);e.preventDefault();}},{passive:false});
  cv.addEventListener('touchend',function(){scratching=false;});
  function resetDare(){
    swapUsed=false;
    var b=document.getElementById('swapBtn');b.style.opacity='';b.textContent='Swap';b.setAttribute('onclick','openSwap()');
    document.getElementById('pill').classList.remove('show');
    document.getElementById('hostimg').src='/assets/candide/cut/monkey.png';
    document.getElementById('from').textContent='Momo dares you & Lila';
    document.getElementById('quote').textContent='“Build me a hideout from three soft things — then climb in and tell each other the scariest thing that isn’t actually scary.”';
    document.getElementById('meta').textContent='5–20 min · inside · pillows & blankets';
    cv.style.display='';cv.style.opacity=1;
    document.getElementById('dareActions').classList.remove('show');
    initScratch();
  }
  go(0);
</script>
