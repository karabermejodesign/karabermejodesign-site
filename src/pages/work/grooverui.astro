---
import Base from "../../layouts/Base.astro";

const summary = "I built and led GrooverUI from audit to adoption — creating a shared system used by designers and engineers to ship faster and more consistently.";

const sections = [
  {
    heading: "How it is now.",
    body: "A shared, token-based design system spanning web and mobile — 20+ components, Storybook documentation, and semantic color tokens powering every surface. The system is the foundation every feature now ships from.",
  },
  {
    heading: "How it was then.",
    body: "When I joined Groover in Q3 2023, a design system had already been attempted — and largely abandoned. The existing setup had major gaps in accessibility, no coherent values architecture, and no real engineering buy-in. Components were inconsistent across surfaces, and every new feature required starting from scratch.",
  },
];

const details = [
  { label: "The many UI iterations we tested around previewing content", body: "We explored over a dozen layout variations for how artists preview campaign submissions — from inline expanders to modal overlays to split-pane views. Each was prototyped at full fidelity and tested with 5–8 curators before settling on the current card-stack pattern." },
  { label: "The rounds of user research that we did", body: "Three rounds of moderated research across curators and artists — discovery interviews, concept testing, and usability validation. Key insight: curators needed to triage fast, artists needed clear feedback. Both shaped the component API and interaction patterns." },
  { label: "We built an AI prototype with actual data", body: "To validate the recommendation engine UX, we built a working prototype connected to real Groover submission data. This let us test how curators responded to AI-suggested matches before committing to production implementation." },
];
---

<Base title="GrooverUI — Design System">
  <div class="cs">

    <nav class="cs-nav" aria-label="Primary">
      <a href="/work">Work</a>
      <a href="/thoughts">Thoughts</a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="mailto:hello@karabermejo.design">Email</a>
    </nav>

    <a href="/" class="cs-back">Back</a>

    <div class="cs-inner">

      <div class="cs-header">
        <h1 class="cs-title">GrooverUI</h1>
        <p class="cs-summary">{summary}</p>
      </div>

      <div class="cs-sections">
        {sections.map((section) => (
          <div class="cs-section">
            <h2 class="cs-section-heading">{section.heading}</h2>
            <p class="cs-section-body">{section.body}</p>
            <div class="cs-section-img" aria-hidden="true"></div>
          </div>
        ))}
      </div>

      <div class="cs-details">
        <h2 class="cs-details-heading">Want to dive into the details?</h2>
        <div class="cs-details-list">
          {details.map((item) => (
            <details class="cs-detail-item">
              <summary class="cs-detail-row">
                <span class="cs-detail-label">{item.label}</span>
                <span class="cs-detail-toggle" aria-hidden="true"></span>
              </summary>
              <div class="cs-detail-body">
                <p>{item.body}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  :global(.site-header),
  :global(.site-footer) {
    display: none;
  }

  .cs {
    position: relative;
    font-family: "Hedvig Letters Sans", sans-serif;
    background: #fafaf9;
    padding: 40px 24px 80px 24px;
    min-height: 100vh;
  }

  .cs-nav {
    position: absolute;
    top: 58px;
    right: 40px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .cs-nav a {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    text-decoration: none;
    letter-spacing: -0.4px;
    line-height: 24px;
    transition: opacity 0.2s ease;
  }

  .cs-nav a:hover {
    opacity: 0.6;
  }

  .cs-back {
    display: inline-block;
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-bottom: 40px;
    transition: opacity 0.2s ease;
  }

  .cs-back:hover {
    opacity: 0.6;
  }

  .cs-inner {
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .cs-header {
    max-width: 1055px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .cs-title {
    font-family: "Hedvig Letters Serif", serif;
    font-size: 38px;
    color: #1a1a1a;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.5px;
  }

  .cs-summary {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    max-width: 586px;
    line-height: 1.5;
  }

  .cs-sections {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 588px;
  }

  .cs-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cs-section-heading {
    font-family: "Hedvig Letters Serif", serif;
    font-size: 24px;
    color: #1a1a1a;
    font-weight: 400;
    line-height: 1.2;
  }

  .cs-section-body {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    line-height: 1.6;
    max-width: none;
  }

  .cs-section-img {
    width: 100%;
    height: 305px;
    background: #d9d9d9;
  }

  .cs-details {
    max-width: 588px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cs-details-heading {
    font-family: "Hedvig Letters Serif", serif;
    font-size: 24px;
    color: #1a1a1a;
    font-weight: 400;
    line-height: 1.2;
  }

  .cs-details-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-detail-item {
    border-bottom: 1px solid #1a1a1a;
  }

  .cs-detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    padding: 12px 0;
    cursor: pointer;
    list-style: none;
  }

  .cs-detail-row::-webkit-details-marker {
    display: none;
  }

  .cs-detail-toggle {
    flex-shrink: 0;
    width: 22px;
    text-align: right;
    transition: transform 0.2s ease;
  }

  .cs-detail-toggle::before {
    content: "+";
  }

  .cs-detail-item[open] .cs-detail-toggle {
    transform: rotate(45deg);
  }

  .cs-detail-body {
    padding: 0 0 16px 0;
  }

  .cs-detail-body p {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    line-height: 1.6;
    max-width: none;
  }

  @media (max-width: 64rem) {
    .cs-nav {
      position: static;
      flex-direction: row;
      gap: 20px;
      margin-bottom: 24px;
      align-items: flex-start;
    }
  }

  @media (min-width: 64rem) {
    .cs {
      padding: 58px 40px 80px 120px;
    }
  }
</style>
