---
import Base from "../layouts/Base.astro";
import { projects } from "../data/projects";
---

<Base title="Home">
  <div class="home">

    <nav class="home-nav" aria-label="Primary">
      <a href="/work">Work</a>
      <a href="/thoughts">Thoughts</a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="mailto:hello@karabermejo.design">Email</a>
    </nav>

    <div class="home-inner">

      <div class="home-top">
        <p class="home-logo">Kara Bermejo</p>
        <p class="home-intro">
          Currently leading product design at <a href="https://groover.co" target="_blank" rel="noopener noreferrer">Groover</a>—a platform that connects independent artists with the opportunities and services that help them grow their music. Previously Design Director at <a href="https://splice.com" target="_blank" rel="noopener noreferrer">Splice</a>. Before that, <a href="https://meetup.com" target="_blank" rel="noopener noreferrer">Meetup</a> and <a href="https://theknot.com" target="_blank" rel="noopener noreferrer">The Knot</a>.
        </p>
      </div>

      <div class="home-statement">
        I care deeply about shipping high-quality products that truly matter to people. That usually means caring about craft—building the right foundations, trusting intuition, practicing empathy, and bringing strong business instincts. It means experimenting, moving fast while staying strategic, and being equal parts IC, leader, and collaborator.
      </div>

      <div class="home-work-list">
        {projects.map((project) => (
          <article class="home-work-item">
            <span class="home-work-date">{project.year}</span>
            <a href={`/work/${project.slug}`} class="home-work-title">{project.title}</a>
            <p class="home-work-desc">{project.description}</p>
            <div class="home-work-img" aria-hidden="true"></div>
          </article>
        ))}
      </div>

    </div>
  </div>
</Base>

<style>
  :global(.site-header),
  :global(.site-footer) {
    display: none;
  }

  .home {
    position: relative;
    font-family: "Hedvig Letters Sans", sans-serif;
    padding: 58px 24px 80px 24px;
    min-height: 100vh;
  }

  .home-nav {
    position: absolute;
    top: 58px;
    right: 40px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .home-nav a {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    text-decoration: none;
    letter-spacing: -0.4px;
    line-height: 24px;
    transition: opacity 0.2s ease;
  }

  .home-nav a:hover {
    opacity: 0.6;
  }

  .home-inner {
    max-width: 1055px;
  }

  .home-top {
    max-width: 50%;
  }

  .home-logo {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    text-decoration: underline;
    margin-bottom: 12px;
    max-width: none;
  }

  .home-intro {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    line-height: 1.5;
    margin-bottom: 48px;
    max-width: none;
  }

  .home-intro a {
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .home-intro a:hover {
    opacity: 0.6;
  }

  .home-statement {
    font-family: "Hedvig Letters Serif", serif;
    font-size: 38px;
    color: #1a1a1a;
    line-height: 1.25;
    letter-spacing: -0.5px;
    margin-bottom: 64px;
    max-width: 83.33%;
  }

  .home-work-list {
    max-width: 50%;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .home-work-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .home-work-date {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #737373;
    line-height: 1.4;
  }

  .home-work-title {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 2px;
    line-height: 1.4;
    transition: opacity 0.2s ease;
  }

  .home-work-title:hover {
    opacity: 0.6;
  }

  .home-work-desc {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    line-height: 1.5;
    max-width: none;
  }

  .home-work-img {
    width: 100%;
    height: 305px;
    background: #d9d9d9;
    border-radius: 4px;
    margin-top: 4px;
  }

  @media (max-width: 64rem) {
    .home-statement {
      font-size: clamp(28px, 5vw, 38px);
    }

    .home-nav {
      position: static;
      flex-direction: row;
      gap: 20px;
      margin-bottom: 40px;
      align-items: flex-start;
    }
  }

  @media (min-width: 64rem) {
    .home {
      padding: 58px 40px 80px 120px;
    }
  }
</style>
