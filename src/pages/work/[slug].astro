---
import Base from "../../layouts/Base.astro";
import { projects, getProjectBySlug } from "../../data/projects";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = () => {
  return projects
    .filter((p) => p.slug !== "grooverui")
    .map((p) => ({ params: { slug: p.slug } }));
};

const { slug } = Astro.params;
const project = getProjectBySlug(slug as string);

if (!project) {
  return Astro.redirect("/work");
}
---

<Base title={project.title} description={project.description}>
  <div class="cs">

    <nav class="cs-nav" aria-label="Primary">
      <a href="/work">Work</a>
      <a href="/thoughts">Thoughts</a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="mailto:hello@karabermejo.design">Email</a>
    </nav>

    <a href="/" class="cs-back">Back</a>

    <div class="cs-inner">

      <div class="cs-header">
        <h1 class="cs-title">{project.title}</h1>
        <p class="cs-summary">{project.summary}</p>
      </div>

      <div class="cs-sections">
        {project.sections.map((section) => (
          <div class="cs-section">
            <h2 class="cs-section-heading">{section.heading}</h2>
            <p class="cs-section-body">{section.body}</p>
            {section.image ? (
              <img src={section.image} alt={section.heading} class="cs-section-img" />
            ) : (
              <div class="cs-section-img" aria-hidden="true"></div>
            )}
          </div>
        ))}
      </div>

      <div class="cs-details">
        <h2 class="cs-details-heading">Want to dive into the details?</h2>
        <div class="cs-details-list">
          {project.details.map((item) => (
            <details class="cs-detail-item">
              <summary class="cs-detail-row">
                <span class="cs-detail-label">{item.label}</span>
                <span class="cs-detail-toggle" aria-hidden="true"></span>
              </summary>
              <div class="cs-detail-body">
                <p>{item.body}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  :global(.site-header),
  :global(.site-footer) {
    display: none;
  }

  .cs {
    position: relative;
    font-family: "Hedvig Letters Sans", sans-serif;
    background: #fafaf9;
    padding: 40px 24px 80px 24px;
    min-height: 100vh;
  }

  .cs-nav {
    position: absolute;
    top: 58px;
    right: 40px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .cs-nav a {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    text-decoration: none;
    letter-spacing: -0.4px;
    line-height: 24px;
    transition: opacity 0.2s ease;
  }

  .cs-nav a:hover {
    opacity: 0.6;
  }

  .cs-back {
    display: inline-block;
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-bottom: 40px;
    transition: opacity 0.2s ease;
  }

  .cs-back:hover {
    opacity: 0.6;
  }

  .cs-inner {
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .cs-header {
    max-width: 1055px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .cs-title {
    font-family: "Hedvig Letters Serif", serif;
    font-size: 38px;
    color: #1a1a1a;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.5px;
  }

  .cs-summary {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    max-width: 586px;
    line-height: 1.5;
  }

  .cs-sections {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 588px;
  }

  .cs-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cs-section-heading {
    font-family: "Hedvig Letters Serif", serif;
    font-size: 24px;
    color: #1a1a1a;
    font-weight: 400;
    line-height: 1.2;
  }

  .cs-section-body {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    line-height: 1.6;
    max-width: none;
  }

  div.cs-section-img {
    width: 100%;
    height: 305px;
    background: #d9d9d9;
  }

  img.cs-section-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .cs-details {
    max-width: 588px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cs-details-heading {
    font-family: "Hedvig Letters Serif", serif;
    font-size: 24px;
    color: #1a1a1a;
    font-weight: 400;
    line-height: 1.2;
  }

  .cs-details-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-detail-item {
    border-bottom: 1px solid #1a1a1a;
  }

  .cs-detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 20px;
    color: #1a1a1a;
    padding: 12px 0;
    cursor: pointer;
    list-style: none;
  }

  .cs-detail-row::-webkit-details-marker {
    display: none;
  }

  .cs-detail-toggle {
    flex-shrink: 0;
    width: 22px;
    text-align: right;
    transition: transform 0.2s ease;
  }

  .cs-detail-toggle::before {
    content: "+";
  }

  .cs-detail-item[open] .cs-detail-toggle {
    transform: rotate(45deg);
  }

  .cs-detail-body {
    padding: 0 0 16px 0;
  }

  .cs-detail-body p {
    font-family: "Hedvig Letters Sans", sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    line-height: 1.6;
    max-width: none;
  }

  @media (max-width: 64rem) {
    .cs-nav {
      position: static;
      flex-direction: row;
      gap: 20px;
      margin-bottom: 24px;
      align-items: flex-start;
    }
  }

  @media (min-width: 64rem) {
    .cs {
      padding: 58px 40px 80px 120px;
    }
  }
</style>
